# Variables d'environnement — Overfitted.io Backend
# Copier ce fichier en .env et remplir les valeurs

# Base de données (SQLite pour dev local, PostgreSQL pour prod)
DATABASE_URL=sqlite+aiosqlite:///./db.sqlite3
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/overfitted

# Redis (queue Celery + cache)
REDIS_URL=redis://localhost:6379/0

# Clé secrète pour sessions admin (itsdangerous + SessionMiddleware)
SECRET_KEY=change-me-in-production

# Admin SQLAdmin — credentials obligatoires en prod
# Si ADMIN_USERNAME ou ADMIN_PASSWORD est vide, l'accès /admin est refusé
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# URL du frontend (CORS)
FRONTEND_URL=http://localhost:3000

# LLM local — Roast Engine
# Compatible LM Studio (http://localhost:1234) et Ollama >= 0.1.24 (/v1 endpoint)
LLM_BASE_URL=http://localhost:1234
LLM_MODEL=gemma-4-e4b-it
# Exemples alternatifs :
# LLM_MODEL=gemma-4-e4b-it
# LLM_BASE_URL=http://localhost:11434   # Ollama
# LLM_MODEL=phi3.5:mini                  # Ollama phi3.5

# OpenAI (optionnel — non utilisé en local si LLM_BASE_URL configuré)
# OPENAI_API_KEY=sk-...

# Stripe (Commerce)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Printful (POD)
PRINTFUL_API_KEY=...
# URL publique de ce serveur — utilisée pour réécrire localhost:8000 avant d'envoyer
# les URLs d'images à Printful (le Mockup Generator doit pouvoir télécharger le fichier).
# En dev : utiliser un tunnel (ex: reverse SSH sur ton VPS OVH, ou ngrok).
# Exemple : PUBLIC_BASE_URL=https://dev.overfitted.io
PUBLIC_BASE_URL=
